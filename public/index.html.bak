<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Splittr — Split expenses, settle fairly</title>
<meta name="description" content="Track shared expenses across trips, flatmates and adventures. Free, private, synced to your Google Drive.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
<style>
/* ── RESET ───────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:#080A0F;color:#F0F2FF;font-family:'Plus Jakarta Sans',system-ui,sans-serif;min-height:100vh;overflow-x:hidden;line-height:1.5;}
a{color:inherit;text-decoration:none;}
.mi{font-family:'Material Icons Round';font-weight:normal;font-style:normal;font-size:20px;line-height:1;letter-spacing:normal;text-transform:none;display:inline-block;white-space:nowrap;word-wrap:normal;direction:ltr;-webkit-font-smoothing:antialiased;user-select:none;}

/* ── TOKENS ──────────────────────────────────────────────── */
:root{
  --w:#FFFFFF;
  --t1:#F4F6FF;
  --t2:rgba(244,246,255,0.55);
  --t3:rgba(244,246,255,0.28);
  --border:rgba(255,255,255,0.08);
  --border2:rgba(255,255,255,0.14);
  --tile:#0F1119;
  --font:'Plus Jakarta Sans',system-ui,sans-serif;
  --r:18px; --rlg:24px; --rxl:32px;
}

/* ── BACKGROUND NOISE ────────────────────────────────────── */
body::before{
  content:'';
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size:200px 200px;
  opacity:.55;
}

/* ── NAV — z-index BELOW menu drawer ────────────────────── */
nav{
  position:fixed;top:0;left:0;right:0;
  z-index:100; /* intentionally below mob-menu (400) */
  height:60px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
  background:#080A0F;
  border-bottom:1px solid transparent;
  overflow:hidden;
  transition:border-color .3s;
}
nav.stuck{border-bottom-color:var(--border);}
.nav-logo{font-size:18px;font-weight:800;letter-spacing:-.4px;color:var(--w);}
.nav-logo span{color:rgba(255,255,255,0.45);}
.nav-center{display:flex;align-items:center;gap:2px;}
.nav-link{font-size:13px;font-weight:500;color:var(--t2);padding:7px 12px;border-radius:100px;transition:color .15s,background .15s;}
.nav-link:hover{color:var(--w);background:rgba(255,255,255,0.07);}
.nav-right{display:flex;align-items:center;gap:8px;}
.nav-btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:8px 18px;
  background:var(--w);color:#080A0F;
  border-radius:100px;border:none;cursor:pointer;
  font-family:var(--font);font-size:13px;font-weight:700;
  transition:opacity .15s,transform .15s;
}
.nav-btn:hover{opacity:.88;transform:translateY(-1px);}
.nav-btn .mi{font-size:14px;}

/* Hamburger */
.ham{
  display:none;flex-direction:column;align-items:center;justify-content:center;
  gap:5px;width:38px;height:38px;
  border:1px solid rgba(255,255,255,0.12);
  background:rgba(255,255,255,0.05);
  border-radius:10px;cursor:pointer;
  transition:background .15s,border-color .15s;
}
.ham:hover{background:rgba(255,255,255,0.10);border-color:rgba(255,255,255,0.22);}
.ham span{display:block;height:1.5px;background:rgba(255,255,255,0.70);border-radius:2px;transition:all .28s cubic-bezier(.4,0,.2,1);}
.ham span:nth-child(1){width:18px;}
.ham span:nth-child(2){width:13px;align-self:flex-end;}
.ham span:nth-child(3){width:18px;}
.ham.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);width:18px;}
.ham.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.ham.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);width:18px;}

/* ── MOBILE MENU DRAWER — z-index ABOVE nav ─────────────── */
.mob-ov{
  position:fixed;inset:0;z-index:350;
  background:rgba(0,0,0,0.60);
  opacity:0;pointer-events:none;
  transition:opacity .28s ease;
}
.mob-ov.open{opacity:1;pointer-events:all;}

.mob-menu{
  position:fixed;top:0;right:0;bottom:0;
  z-index:400; /* above nav (100) so it covers the top bar */
  width:272px;
  background:#0A0C12;
  border-left:1px solid rgba(255,255,255,0.08);
  transform:translateX(100%);
  transition:transform .30s cubic-bezier(0.32,0,0.15,1);
  display:flex;flex-direction:column;
  overflow:hidden;
}
.mob-menu.open{
  transform:translateX(0);
  box-shadow:-24px 0 72px rgba(0,0,0,0.80);
}
/* top highlight line */
.mob-menu::after{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.10),transparent);
  pointer-events:none;z-index:1;
}

.mob-inner{
  display:flex;flex-direction:column;
  height:100%;
  overflow-y:auto;overflow-x:hidden;
}

/* close + brand row — sits where nav bar would be */
.mob-topbar{
  height:60px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 18px;
  border-bottom:1px solid rgba(255,255,255,0.07);
  flex-shrink:0;
}
.mob-brand{font-size:17px;font-weight:800;letter-spacing:-.4px;color:var(--w);}
.mob-brand span{color:rgba(255,255,255,0.40);}
.mob-close{
  width:32px;height:32px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.11);
  border-radius:8px;cursor:pointer;
  color:rgba(255,255,255,0.60);
  font-family:'Material Icons Round';
  font-size:17px;line-height:1;
  font-style:normal;font-weight:normal;
  -webkit-font-smoothing:antialiased;
  user-select:none;
  transition:background .13s,color .13s,border-color .13s;
}
.mob-close:hover{background:rgba(255,255,255,0.13);color:var(--w);border-color:rgba(255,255,255,0.22);}

.mob-sec{
  font-size:9px;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:rgba(255,255,255,0.22);
  padding:20px 20px 6px;
}
.mob-link{
  display:flex;align-items:center;gap:12px;
  margin:2px 10px;padding:11px 12px;
  color:rgba(255,255,255,0.65);
  font-size:14px;font-weight:500;
  border-radius:10px;
  border:1px solid transparent;
  transition:background .12s,color .12s,border-color .12s;
}
.mob-link:hover,.mob-link:active{
  background:rgba(255,255,255,0.07);
  border-color:rgba(255,255,255,0.10);
  color:var(--w);
}
.mob-link .mi{font-size:17px;color:rgba(255,255,255,0.28);width:20px;text-align:center;flex-shrink:0;transition:color .12s;}
.mob-link:hover .mi,.mob-link:active .mi{color:rgba(255,255,255,0.62);}
.mob-link.mob-cta{
  background:rgba(255,255,255,0.09);
  border-color:rgba(255,255,255,0.14);
  color:var(--w);font-weight:600;
}
.mob-link.mob-cta .mi{color:rgba(255,255,255,0.55);}
.mob-link.mob-cta:hover{background:rgba(255,255,255,0.14);border-color:rgba(255,255,255,0.22);}
.mob-div{height:1px;background:rgba(255,255,255,0.06);margin:8px 16px;}
.mob-foot{margin-top:auto;padding:20px;font-size:10.5px;color:rgba(255,255,255,0.18);letter-spacing:.03em;}

/* ── HERO ────────────────────────────────────────────────── */
.hero{
  position:relative;z-index:10;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
  padding:140px 24px 88px;
  max-width:720px;margin:0 auto;
}
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.hero-h{
  font-size:clamp(40px,10vw,80px);
  font-weight:800;line-height:1.04;
  letter-spacing:-2.5px;
  color:var(--w);
  margin-bottom:20px;
  opacity:0;animation:up .7s .1s both;
}
.hero-h .dim{color:rgba(255,255,255,0.38);}

.hero-sub{
  font-size:clamp(15px,2vw,17px);
  color:rgba(255,255,255,0.48);
  line-height:1.75;max-width:460px;
  margin-bottom:36px;
  opacity:0;animation:up .7s .22s both;
}

.hero-btns{
  display:flex;gap:10px;justify-content:center;flex-wrap:wrap;
  opacity:0;animation:up .7s .34s both;
}
.btn-primary{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 30px;
  background:var(--w);color:#080A0F;
  border-radius:100px;border:none;cursor:pointer;
  font-family:var(--font);font-size:14.5px;font-weight:700;
  transition:opacity .15s,transform .15s;
  letter-spacing:-.1px;
}
.btn-primary:hover{opacity:.88;transform:translateY(-2px);}
.btn-primary .mi{font-size:17px;}

.hero-terms{
  font-size:11px;color:rgba(255,255,255,0.25);
  margin-top:14px;line-height:1.7;
  opacity:0;animation:up .7s .44s both;
}
.hero-terms a{color:rgba(255,255,255,0.45);text-decoration:underline;text-underline-offset:2px;}
.hero-terms a:hover{color:rgba(255,255,255,0.75);}

.trust{
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
  justify-content:center;margin-top:36px;
  opacity:0;animation:up .7s .50s both;
}
.trust-item{display:flex;align-items:center;gap:5px;font-size:11.5px;color:rgba(255,255,255,0.28);}
.trust-item .mi{font-size:13px;color:rgba(255,255,255,0.25);}
.trust-sep{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.12);}

/* ── SECTION COMMONS ─────────────────────────────────────── */
.section{
  position:relative;z-index:10;
  max-width:1100px;margin:0 auto;
  padding:80px 40px;
}
.eyebrow{
  display:inline-flex;align-items:center;gap:7px;
  font-size:10.5px;font-weight:700;letter-spacing:.15em;
  text-transform:uppercase;color:rgba(255,255,255,0.38);
  margin-bottom:14px;
}
.eyebrow::before{content:'';width:14px;height:1.5px;border-radius:2px;background:rgba(255,255,255,0.38);}
.section-h{
  font-size:clamp(26px,3vw,44px);font-weight:800;
  letter-spacing:-1.5px;line-height:1.08;color:var(--w);
  margin-bottom:12px;
}
.section-h span{color:rgba(255,255,255,0.40);}
.section-p{font-size:15px;color:rgba(255,255,255,0.42);max-width:460px;line-height:1.78;margin-bottom:48px;}

/* ── FEATURE GRID ────────────────────────────────────────── */
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.feat-tile{
  background:var(--tile);
  border:1px solid rgba(255,255,255,0.07);
  border-radius:var(--rlg);
  padding:26px 22px;
  transition:background .2s,border-color .2s,transform .2s;
  cursor:default;
}
.feat-tile:hover{background:#111420;border-color:rgba(255,255,255,0.13);transform:translateY(-3px);}
.feat-tile.wide{grid-column:span 2;}
.feat-tile.hl{border-color:rgba(255,255,255,0.13);}

.feat-ic{
  width:42px;height:42px;border-radius:11px;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.10);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:16px;
}
.feat-ic .mi{font-size:20px;color:rgba(255,255,255,0.55);}
.feat-ic.wh{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.18);}
.feat-ic.wh .mi{color:rgba(255,255,255,0.85);}

.feat-title{font-size:14.5px;font-weight:700;color:rgba(255,255,255,0.88);margin-bottom:7px;}
.feat-body{font-size:13px;color:rgba(255,255,255,0.38);line-height:1.72;}

/* ── HOW IT WORKS ────────────────────────────────────────── */
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:48px;position:relative;}
.how-line{position:absolute;top:27px;left:calc(16.7% + 27px);right:calc(16.7% + 27px);height:1px;background:rgba(255,255,255,0.07);z-index:0;}
.how-step{display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 16px;position:relative;z-index:1;}
.how-num{
  width:54px;height:54px;border-radius:50%;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.10);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;font-weight:800;color:rgba(255,255,255,0.45);
  margin-bottom:20px;
}
.how-step:nth-child(2) .how-num{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.22);color:var(--w);}
.how-title{font-size:14.5px;font-weight:700;color:rgba(255,255,255,0.85);margin-bottom:8px;}
.how-body{font-size:13px;color:rgba(255,255,255,0.38);line-height:1.72;}

/* ── CTA BOX ─────────────────────────────────────────────── */
.cta-wrap{position:relative;z-index:10;padding:0 40px 100px;}
.cta-box{
  max-width:680px;margin:0 auto;text-align:center;
  background:#0D1018;
  border:1px solid rgba(255,255,255,0.10);
  border-radius:var(--rxl);
  padding:68px 48px;
  position:relative;overflow:hidden;
}
.cta-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.18),transparent);
}
.cta-h{font-size:clamp(24px,3vw,38px);font-weight:800;letter-spacing:-1.5px;color:var(--w);margin-bottom:12px;}
.cta-p{font-size:15px;color:rgba(255,255,255,0.40);line-height:1.75;margin-bottom:32px;}
.cta-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.cta-note{font-size:11px;color:rgba(255,255,255,0.22);margin-top:14px;line-height:1.7;}
.cta-note a{color:rgba(255,255,255,0.38);text-decoration:underline;text-underline-offset:2px;}
.cta-note a:hover{color:rgba(255,255,255,0.65);}

/* ── FOOTER ──────────────────────────────────────────────── */
.footer-outer{position:relative;z-index:10;border-top:1px solid rgba(255,255,255,0.07);}
.footer-inner{
  max-width:1100px;margin:0 auto;
  padding:26px 40px;
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:14px;
}
.foot-logo{font-size:16px;font-weight:800;letter-spacing:-.4px;color:var(--w);}
.foot-logo span{color:rgba(255,255,255,0.35);}
.foot-links{display:flex;gap:20px;}
.foot-link{font-size:12.5px;color:rgba(255,255,255,0.28);transition:color .14s;}
.foot-link:hover{color:rgba(255,255,255,0.60);}
.foot-copy{font-size:11.5px;color:rgba(255,255,255,0.20);}

/* ── SCROLL REVEAL ───────────────────────────────────────── */
.reveal{opacity:0;transform:translateY(14px);transition:opacity .5s,transform .5s;}
.reveal.visible{opacity:1;transform:translateY(0);}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media(max-width:880px){
  .feat-grid{grid-template-columns:1fr 1fr;}
  .feat-tile.wide{grid-column:span 2;}
  .how-grid{grid-template-columns:1fr;}
  .how-line{display:none;}
  .how-step{padding:0;margin-bottom:28px;}
  .section,.cta-wrap{padding-left:18px;padding-right:18px;}
  .nav-center,.nav-btn,.nav-ghost{display:none;}
  .ham{display:flex;}
  .footer-inner{flex-direction:column;text-align:center;padding:22px 18px;}
  .foot-links{flex-wrap:wrap;justify-content:center;}
}
@media(max-width:540px){
  .feat-grid{grid-template-columns:1fr;}
  .feat-tile.wide{grid-column:span 1;}
  .hero{padding-top:108px;}
  .cta-box{padding:44px 24px;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav id="topNav">
  <a href="/" class="nav-logo">Split<span>tr</span></a>
  <div class="nav-center">
    <a href="#features" class="nav-link">Features</a>
    <a href="#how" class="nav-link">How it works</a>
    <a href="/privacy" class="nav-link">Privacy</a>
    <a href="/terms" class="nav-link">Terms</a>
  </div>
  <div class="nav-right">
    <a href="/login" class="nav-btn"><span class="mi">rocket_launch</span>Get Started</a>
    <button class="ham" id="ham" aria-label="Open menu" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- MOBILE MENU — z-index 400, covers nav bar -->
<div class="mob-ov" id="mobOv" onclick="closeMenu()"></div>
<aside class="mob-menu" id="mobMenu" aria-label="Mobile navigation">
  <div class="mob-inner">

    <div class="mob-topbar">
      <span class="mob-brand">Split<span>tr</span></span>
      <button class="mob-close" onclick="closeMenu()" aria-label="Close menu">close</button>
    </div>

    <div class="mob-sec">App</div>
    <a href="/login" class="mob-link mob-cta" onclick="closeMenu()">
      <span class="mi">rocket_launch</span>Get Started
    </a>

    <div class="mob-div"></div>
    <div class="mob-sec">Explore</div>
    <a href="#features" class="mob-link" onclick="closeMenu()">
      <span class="mi">auto_awesome</span>Features
    </a>
    <a href="#how" class="mob-link" onclick="closeMenu()">
      <span class="mi">help_outline</span>How it works
    </a>

    <div class="mob-div"></div>
    <div class="mob-sec">Legal</div>
    <a href="/privacy" class="mob-link" onclick="closeMenu()">
      <span class="mi">shield</span>Privacy Policy
    </a>
    <a href="/terms" class="mob-link" onclick="closeMenu()">
      <span class="mi">gavel</span>Terms of Service
    </a>

    <div class="mob-foot">&#169; 2025 Splittr &middot; Free forever</div>
  </div>
</aside>

<!-- HERO -->
<section class="hero" aria-labelledby="hero-heading">
  <h1 class="hero-h" id="hero-heading">
    Split expenses,<br>
    <span class="dim">settle fairly.</span>
  </h1>
  <p class="hero-sub">
    Track shared costs across trips, flatmates and adventures.
    The maths is handled so your friendships stay intact.
  </p>
  <div class="hero-btns">
    <a href="/login" class="btn-primary">
      <span class="mi">rocket_launch</span>Get Started
    </a>
  </div>
  <p class="hero-terms">
    By clicking Get Started you agree to our
    <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>.
  </p>
  <div class="trust">
    <span class="trust-item"><span class="mi">cloud_sync</span>Drive backup</span>
    <span class="trust-sep"></span>
    <span class="trust-item"><span class="mi">picture_as_pdf</span>PDF &amp; CSV export</span>
    <span class="trust-sep"></span>
    <span class="trust-item"><span class="mi">currency_exchange</span>10+ currencies</span>
    <span class="trust-sep"></span>
    <span class="trust-item"><span class="mi">lock</span>Your data only</span>
  </div>
</section>

<!-- FEATURES -->
<section class="section" id="features">
  <div class="eyebrow reveal">Everything you need</div>
  <h2 class="section-h reveal">Built for real trips,<br><span>not spreadsheets.</span></h2>
  <p class="section-p reveal">Every feature is designed around how groups actually split things: messy, unequal and across different currencies.</p>

  <div class="feat-grid">
    <div class="feat-tile wide hl reveal">
      <div class="feat-ic wh"><span class="mi">handshake</span></div>
      <div class="feat-title">Smart Settlements</div>
      <div class="feat-body">Minimises the number of transactions needed to clear all debts. The algorithm finds the optimal path so no one pays more times than necessary.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic wh"><span class="mi">cloud_sync</span></div>
      <div class="feat-title">Google Drive Backup</div>
      <div class="feat-body">Stored in a hidden app folder in your own Google Drive. No Splittr servers hold your expenses.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic"><span class="mi">receipt_long</span></div>
      <div class="feat-title">Flexible Split Modes</div>
      <div class="feat-body">Split equally or set custom amounts per person. Perfect for when someone only ordered a salad.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic"><span class="mi">currency_exchange</span></div>
      <div class="feat-title">10+ Currencies</div>
      <div class="feat-body">INR, USD, EUR, GBP, JPY, CAD, AUD, SGD, CHF and MXN. Each group has its own currency.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic wh"><span class="mi">picture_as_pdf</span></div>
      <div class="feat-title">PDF &amp; CSV Export</div>
      <div class="feat-body">Generate a full expense report as a PDF or export a clean CSV for your own records.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic"><span class="mi">bar_chart</span></div>
      <div class="feat-title">Spending Stats</div>
      <div class="feat-body">Category breakdowns, per-member summaries and a full timeline of every expense in the group.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic"><span class="mi">cloud_off</span></div>
      <div class="feat-title">Works Offline</div>
      <div class="feat-body">All calculations run in the browser. Log expenses and view settlements without internet.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic wh"><span class="mi">share</span></div>
      <div class="feat-title">Share Summary</div>
      <div class="feat-body">Generate a shareable snapshot of the group balance and send it to anyone in seconds.</div>
    </div>
    <div class="feat-tile reveal">
      <div class="feat-ic"><span class="mi">edit_calendar</span></div>
      <div class="feat-title">Join Date Tracking</div>
      <div class="feat-body">Members can have different join dates so late additions only share expenses from when they joined.</div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
