# Google OAuth — console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session secret — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_64_char_random_hex_string

# App URL — your Vercel domain (no trailing slash)
APP_URL=https://your-app.vercel.app

# Drive file name (can leave as default)
DRIVE_FILE_NAME=splittr-data.json

NODE_ENV=production
